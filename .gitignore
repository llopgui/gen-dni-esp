# =============================================================================
# gen-dni-esp — Artefactos locales, compilación y caché (no código ni assets)
# =============================================================================
# Estructura relevante: src/, tests/, tools/, assets/, GeneradorDNI.spec.
# Reglas de Cursor/VS Code/JetBrains: ignoradas (solo local).
# Nota: NO ignorar *.spec: este repositorio versiona GeneradorDNI.spec.

# --- Secretos y variables de entorno
.env
.env.*
!.env.example

# --- Entornos virtuales
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# --- Bytecode y extensiones nativas
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Artefactos de empaquetado (setuptools / wheel) y salida de PyInstaller
#     (tools/build_exe.py → build/, dist/; no subir .exe generados)
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# --- PyInstaller (artefactos de compilación; el fichero .spec del repo sí va a Git)
*.manifest

# --- Pruebas, cobertura y entornos de test
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# --- Linters, formateadores y comprobación de tipos
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/
.pyre/

# --- Registros y cachés de documentación local
*.log
docs/_build/
/site

# --- Jupyter (prototipos opcionales)
.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Gestores de dependencias (metadatos locales)
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/

# --- Cython (depuración)
cython_debug/

# --- IDE / editor (configuración local; no subir a GitHub)
.idea/
.vscode/
.cursor/
.cursorrules
*.code-workspace
.editorconfig

# --- Sistema operativo
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Publicación PyPI (credenciales)
.pypirc
pyproject.toml
.flake8
.gitignore
